# =============================================================================
# What's the 661 - Environment Variables
# =============================================================================
# INSTRUCTIONS:
# 1. Copy this file to .env.local
# 2. Fill in the real values below
# 3. .env.local is gitignored and will NOT be committed
# =============================================================================

# Slack Webhook URL for receiving nominations
# Get this from: Slack App > Incoming Webhooks > Add New Webhook
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# OpenAI API Key for AI-powered showrunner insights
# Get this from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here
